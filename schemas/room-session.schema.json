{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://round-table-workspace.local/schemas/room-session.schema.json",
  "title": "Round Table Room Session State",
  "description": "Portable local-first session state for the explicit-only /room workflow.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "workflow",
    "user_question",
    "current_focus",
    "panel",
    "turns",
    "summaries",
    "handoff_packet",
    "claim_boundary",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "description": "Version of this session-state schema.",
      "const": "0.1.0"
    },
    "session_id": {
      "description": "Stable room session id. It normally maps to the runtime room_id.",
      "type": "string",
      "minLength": 1,
      "pattern": "^room[-_A-Za-z0-9]+$"
    },
    "workflow": {
      "description": "Workflow discriminator.",
      "const": "room"
    },
    "user_question": {
      "description": "Original user question copied from the explicit /room entry.",
      "type": "string",
      "minLength": 1
    },
    "current_focus": {
      "description": "Current /focus value, or null when no focus has been set.",
      "type": [
        "string",
        "null"
      ]
    },
    "panel": {
      "description": "Selected room roster with long-lived role metadata.",
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/panel_member"
      }
    },
    "turns": {
      "description": "Visible room turns generated by room-chat.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/turn"
      }
    },
    "summaries": {
      "description": "Summary snapshots produced by /summary.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/summary"
      }
    },
    "handoff_packet": {
      "description": "Null until /upgrade-to-debate creates a handoff packet. RTW-008 will replace the open object with a dedicated schema reference.",
      "type": [
        "object",
        "null"
      ]
    },
    "claim_boundary": {
      "description": "Claim-safe support boundary for this room session.",
      "$ref": "#/$defs/claim_boundary"
    },
    "created_at": {
      "description": "ISO 8601 UTC timestamp when the session was created.",
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "description": "ISO 8601 UTC timestamp when the session was last updated.",
      "type": "string",
      "format": "date-time"
    },
    "runtime_state": {
      "description": "Optional compatibility snapshot for the current checked-in room runtime state shape.",
      "$ref": "#/$defs/runtime_state"
    }
  },
  "$defs": {
    "panel_member": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_id",
        "short_name",
        "role_summary",
        "structural_role"
      ],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "short_name": {
          "type": "string",
          "minLength": 1
        },
        "role_summary": {
          "type": "string",
          "minLength": 1
        },
        "structural_role": {
          "type": "string",
          "enum": [
            "offensive",
            "defensive",
            "moderate"
          ]
        }
      }
    },
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turn_id",
        "stage",
        "active_focus",
        "user_input",
        "speakers",
        "cited_agents",
        "warnings",
        "meta"
      ],
      "properties": {
        "turn_id": {
          "type": "integer",
          "minimum": 1
        },
        "stage": {
          "$ref": "#/$defs/room_stage"
        },
        "active_focus": {
          "type": [
            "string",
            "null"
          ]
        },
        "user_input": {
          "type": "string",
          "minLength": 1
        },
        "speakers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/turn_speaker"
          }
        },
        "cited_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "meta": {
          "$ref": "#/$defs/turn_meta"
        }
      }
    },
    "turn_speaker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_id",
        "short_name",
        "role",
        "content"
      ],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "short_name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "primary",
            "support",
            "challenge",
            "synthesizer"
          ]
        },
        "content": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "turn_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated_at_turn",
        "prompt_version",
        "tokens_used_estimate"
      ],
      "properties": {
        "generated_at_turn": {
          "type": "integer",
          "minimum": 1
        },
        "prompt_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "tokens_used_estimate": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turn_id",
        "consensus_points",
        "open_questions",
        "tension_points",
        "recommended_next_step",
        "generated_at"
      ],
      "properties": {
        "turn_id": {
          "type": "integer",
          "minimum": 0
        },
        "consensus_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tension_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_next_step": {
          "type": "string",
          "minLength": 1
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_first",
        "host_live",
        "provider_live",
        "notes"
      ],
      "properties": {
        "local_first": {
          "type": "boolean",
          "const": true
        },
        "host_live": {
          "type": "string",
          "enum": [
            "not_claimed",
            "fixture_only",
            "pending_live_validation",
            "live_passed"
          ]
        },
        "provider_live": {
          "type": "string",
          "enum": [
            "not_claimed",
            "pending_live_validation",
            "live_passed"
          ]
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "runtime_state": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "room_id",
        "title",
        "mode",
        "original_topic",
        "primary_type",
        "active_focus",
        "agents",
        "agent_roles",
        "conversation_log",
        "silent_rounds",
        "turn_count",
        "last_stage",
        "recent_log",
        "upgrade_signal"
      ],
      "properties": {
        "room_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "standard",
            "focused",
            "upgrading"
          ]
        },
        "original_topic": {
          "type": "string",
          "minLength": 1
        },
        "primary_type": {
          "type": "string",
          "minLength": 1
        },
        "secondary_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "active_focus": {
          "type": [
            "string",
            "null"
          ]
        },
        "agents": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "string"
          }
        },
        "agent_roles": {
          "type": "object",
          "additionalProperties": true
        },
        "conversation_log": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/turn"
          }
        },
        "consensus_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tension_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_next_step": {
          "type": [
            "string",
            "null"
          ]
        },
        "silent_rounds": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "turn_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_stage": {
          "$ref": "#/$defs/room_stage"
        },
        "recent_log": {
          "type": "string"
        },
        "upgrade_signal": {
          "type": [
            "object",
            "null"
          ]
        },
        "last_summary_turn": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "room_stage": {
      "type": "string",
      "enum": [
        "explore",
        "simulate",
        "stress_test",
        "converge",
        "decision"
      ]
    }
  }
}
