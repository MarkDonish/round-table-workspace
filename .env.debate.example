# Chat Completions-compatible provider config for /debate live prompt calls.
# Fill these values locally and load them explicitly with:
# python3 .codex/skills/room-skill/runtime/chat_completions_executor.py --provider-scope debate --env-file .env.debate --check-provider-config
# The checked-in provider preflight treats these unchanged example values as not configured.

DEBATE_CHAT_COMPLETIONS_URL=https://your-provider.example/v1/chat/completions
DEBATE_CHAT_COMPLETIONS_MODEL=your-model-name
DEBATE_PROVIDER_AUTH_BEARER=your-provider-token
DEBATE_PROVIDER_TIMEOUT_SECONDS=60
