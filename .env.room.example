# Optional Chat Completions-compatible provider config for /room live prompt calls.
# You do not need this file, a provider URL, or a provider token for the local
# Codex /room mainline. Use this only when intentionally validating the external
# provider fallback/regression lane.
# Fill these values locally and load them explicitly with:
# python3 .codex/skills/room-skill/runtime/chat_completions_executor.py --env-file .env.room --check-provider-config
# The checked-in provider preflight treats these unchanged example values as not configured.

ROOM_CHAT_COMPLETIONS_URL=https://your-provider.example/v1/chat/completions
ROOM_CHAT_COMPLETIONS_MODEL=your-model-name
ROOM_PROVIDER_AUTH_BEARER=your-provider-token
ROOM_PROVIDER_TIMEOUT_SECONDS=60
